# ===========================
# Listarr Environment Configuration
# ===========================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================
# Flask Configuration
# ===========================
# OPTIONAL: Override auto-generated SECRET_KEY (auto-generated to instance/.secret_key on first run)
# Only set this if you need to share sessions across multiple instances
# LISTARR_SECRET_KEY=your_custom_secret_key_here

# Flask environment (development, production)
FLASK_ENV=production

# ===========================
# Encryption Key (Optional)
# ===========================
# By default, the encryption key is loaded from instance/.fernet_key
# If you prefer to use an environment variable instead, uncomment below:
# FERNET_KEY=your_base64_encoded_32_byte_key_here

# ===========================
# Application Settings
# ===========================
# Port to run the application on (default: 5000)
PORT=5000

# ===========================
# API Keys (Managed via UI)
# ===========================
# TMDB, Radarr, and Sonarr API keys are configured through the web interface
# They are stored encrypted in the database, not in environment variables

# ===========================
# Optional: Logging
# ===========================
# LOG_LEVEL=INFO
# LOG_FILE=/app/instance/listarr.log
